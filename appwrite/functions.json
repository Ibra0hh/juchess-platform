[
  {
    "$id": "admin-actions",
    "name": "JuChess Admin Actions",
    "runtime": "node-22",
    "path": "functions/admin-actions",
    "entrypoint": "src/main.js",
    "commands": "npm install",
    "execute": [
      "team:admins",
      "team:organizers"
    ],
    "events": [],
    "schedule": "",
    "timeout": 15,
    "enabled": true,
    "logging": true,
    "ignore": [
      "node_modules",
      ".git"
    ],
    "scopes": [
      "databases.read",
      "databases.write",
      "rows.read",
      "rows.write",
      "documents.read",
      "documents.write",
      "users.read",
      "users.write"
    ],
    "vars": [
      {
        "key": "JUCHESS_DATABASE_ID",
        "value": "juchess"
      }
    ]
  },
  {
    "$id": "access-guards",
    "name": "JuChess Access Guards",
    "runtime": "node-22",
    "path": "functions/access-guards",
    "entrypoint": "src/main.js",
    "commands": "npm install",
    "execute": [
      "any"
    ],
    "events": [],
    "schedule": "",
    "timeout": 10,
    "enabled": true,
    "logging": true,
    "ignore": [
      "node_modules",
      ".git"
    ],
    "scopes": [
      "databases.read",
      "rows.read",
      "documents.read"
    ],
    "vars": [
      {
        "key": "JUCHESS_DATABASE_ID",
        "value": "juchess"
      }
    ]
  }
]
