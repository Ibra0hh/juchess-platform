[
  {
    "$id": "admin-actions",
    "name": "JuChess Admin Actions",
    "runtime": "node-22",
    "path": "functions/admin-actions",
    "entrypoint": "src/main.js",
    "commands": "npm install",
    "execute": [
      "team:admin_super_admins",
      "team:admin_staff",
      "users"
    ],
    "events": [],
    "schedule": "* * * * *",
    "timeout": 60,
    "enabled": true,
    "logging": true,
    "ignore": [
      "node_modules",
      ".git"
    ],
    "scopes": [
      "databases.read",
      "databases.write",
      "rows.read",
      "rows.write",
      "documents.read",
      "documents.write",
      "teams.read",
      "teams.write",
      "users.read",
      "users.write",
      "providers.read",
      "messages.write"
    ],
    "vars": [
      {
        "key": "JUCHESS_DATABASE_ID",
        "value": "juchess"
      },
      {
        "key": "JUCHESS_PUBLIC_WEB_URL",
        "value": "https://ibra0hh.github.io/juchess-platform/web"
      }
    ]
  },
  {
    "$id": "player-actions",
    "name": "JuChess Player Actions",
    "runtime": "node-22",
    "path": "functions/player-actions",
    "entrypoint": "src/main.js",
    "commands": "npm install",
    "execute": [
      "users"
    ],
    "events": [],
    "schedule": "",
    "timeout": 15,
    "enabled": true,
    "logging": true,
    "ignore": [
      "node_modules",
      ".git"
    ],
    "scopes": [
      "databases.read",
      "databases.write",
      "rows.read",
      "rows.write",
      "documents.read",
      "documents.write",
      "users.read"
    ],
    "vars": [
      {
        "key": "JUCHESS_DATABASE_ID",
        "value": "juchess"
      }
    ]
  },
  {
    "$id": "attendance-actions",
    "name": "JuChess Attendance Links",
    "runtime": "node-22",
    "path": "functions/attendance-actions",
    "entrypoint": "src/main.js",
    "commands": "npm install",
    "execute": [
      "any"
    ],
    "events": [],
    "schedule": "",
    "timeout": 10,
    "enabled": true,
    "logging": true,
    "ignore": [
      "node_modules",
      ".git"
    ],
    "scopes": [
      "databases.read",
      "databases.write",
      "rows.read",
      "rows.write",
      "documents.read",
      "documents.write"
    ],
    "vars": [
      {
        "key": "JUCHESS_DATABASE_ID",
        "value": "juchess"
      }
    ]
  },
  {
    "$id": "access-guards",
    "name": "JuChess Access Guards",
    "runtime": "node-22",
    "path": "functions/access-guards",
    "entrypoint": "src/main.js",
    "commands": "npm install",
    "execute": [
      "any"
    ],
    "events": [],
    "schedule": "",
    "timeout": 10,
    "enabled": true,
    "logging": true,
    "ignore": [
      "node_modules",
      ".git"
    ],
    "scopes": [
      "databases.read",
      "rows.read",
      "documents.read"
    ],
    "vars": [
      {
        "key": "JUCHESS_DATABASE_ID",
        "value": "juchess"
      }
    ]
  }
]
