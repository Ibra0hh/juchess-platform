{
  "databaseId": "juchess",
  "teams": ["admin_super_admins", "admin_staff", "admins", "organizers", "members"],
  "tables": {
    "admin_profiles": {
      "fields": {
        "accountId": "string|required|unique",
        "email": "email|required|unique",
        "displayName": "string|required",
        "role": "enum:superAdmin,admin,organizer",
        "status": "enum:active,suspended",
        "teamId": "string",
        "membershipId": "string",
        "createdByAdminId": "string",
        "createdAt": "datetime|required",
        "notes": "string"
      }
    },
    "profiles": {
      "fields": {
        "accountId": "string|required|unique",
        "displayName": "string|required",
        "universityId": "string|unique",
        "email": "email|required",
        "phone": "string|unique",
        "rating": "integer|default:1200",
        "role": "enum:member,organizer,admin",
        "status": "enum:pending,active,suspended",
        "avatarFileId": "string",
        "chessComUsername": "string|unique",
        "lichessUsername": "string|unique"
      }
    },
    "tournaments": {
      "fields": {
        "slug": "string|required|unique",
        "name": "string|required",
        "status": "enum:draft,upcoming,active,completed,archived",
        "format": "string|required",
        "timeControl": "string|required",
        "roundsTotal": "integer",
        "currentRound": "integer",
        "startsAt": "datetime",
        "endsAt": "datetime",
        "playMode": "enum:inPerson,online|default:inPerson",
        "onlinePlatform": "enum:chessCom,lichess,juchess",
        "location": "string",
        "capacity": "integer",
        "description": "string",
        "bracketSnapshot": "longtext",
        "physicalBoards": "integer|default:3|min:1|max:64",
        "firstMoveGraceSeconds": "integer|min:5|max:600",
        "disconnectGraceSeconds": "integer|min:15|max:600",
        "chatPolicy": "enum:full,preset,disabled|default:full",
        "fairPlayMode": "enum:standard,strict,proctored|default:standard",
        "createdByProfileId": "string|required"
      }
    },
    "registrations": {
      "note": "World-readable (public players list and participant counts). Rows are created ONLY by the player-actions function; clients have no create permission. Never store a secret here.",
      "permissions": ["read(\"any\")", "update(\"team:admins\")", "delete(\"team:admins\")", "update(\"team:organizers\")"],
      "rowSecurity": true,
      "fields": {
        "tournamentId": "string|required",
        "profileId": "string|required",
        "status": "enum:pending,confirmed,waitlisted,cancelled",
        "seed": "integer",
        "checkInCode": "string|deprecated:always-null-see-check_ins",
        "checkedIn": "boolean|default:false"
      }
    },
    "check_ins": {
      "note": "Private check-in passes. No table-level permissions: each row grants read only to its owner's account, and staff read them through admin-actions using the server key. Written by admin-actions on registration confirm; deleted on cancel.",
      "permissions": [],
      "rowSecurity": true,
      "indexes": {
        "tournament_profile": "key:tournamentId,profileId"
      },
      "fields": {
        "tournamentId": "string|required",
        "profileId": "string|required",
        "registrationId": "string|required",
        "code": "string|required",
        "checkedIn": "boolean|default:false",
        "checkedInAt": "string"
      }
    },
    "games": {
      "indexes": {
        "game_status": "key:status",
        "white_profile_status": "key:whiteProfileId,status",
        "black_profile_status": "key:blackProfileId,status",
        "tournament_status": "key:tournamentId,status"
      },
      "fields": {
        "tournamentId": "string|required",
        "round": "integer|required",
        "board": "integer|required",
        "whiteProfileId": "string|required",
        "blackProfileId": "string|required",
        "status": "enum:scheduled,live,completed,forfeit",
        "result": "enum:1-0,0-1,1/2-1/2,*",
        "pgn": "string|max:50000",
        "moveVersion": "integer|default:0|min:0",
        "lastMoveAt": "datetime",
        "whiteTimeMs": "integer|min:0",
        "blackTimeMs": "integer|min:0",
        "turnStartedAt": "datetime",
        "scheduledStartAt": "datetime",
        "firstMoveDeadlineAt": "datetime",
        "clockDeadlineAt": "datetime",
        "terminationReason": "enum:checkmate,draw,resignation,timeout,noShow,forfeit,cancelled",
        "forfeitedProfileId": "string",
        "procedureWave": "integer",
        "physicalBoard": "integer",
        "queuePosition": "integer",
        "startedAt": "datetime",
        "finishedAt": "datetime"
      }
    },
    "game_messages": {
      "note": "Private per-game chat. Rows are created by admin-actions and grant read access only to the two player accounts. Finished-game threads remain readable but become write-locked by the function.",
      "permissions": [],
      "rowSecurity": true,
      "indexes": {
        "game_created": "key:gameId,createdAt",
        "tournament_created": "key:tournamentId,createdAt"
      },
      "fields": {
        "gameId": "string|required",
        "tournamentId": "string|required",
        "senderProfileId": "string|required",
        "kind": "enum:text,preset,system|default:text",
        "body": "string|required|max:500",
        "status": "enum:active,removed|default:active",
        "createdAt": "datetime|required",
        "removedAt": "datetime",
        "removedByProfileId": "string"
      }
    },
    "fair_play_events": {
      "note": "Server-written fair-play telemetry. No client read permissions; organizers consume summaries through admin-actions.",
      "permissions": [],
      "indexes": {
        "game_time": "key:gameId,occurredAt",
        "profile_time": "key:profileId,occurredAt",
        "tournament_time": "key:tournamentId,occurredAt"
      },
      "fields": {
        "gameId": "string|required",
        "tournamentId": "string|required",
        "profileId": "string|required",
        "sessionId": "string|required",
        "eventType": "enum:heartbeat,tabHidden,tabVisible,windowBlur,windowFocus,fullscreenExit,disconnect,reconnect,analysisAttempt",
        "durationMs": "integer|min:0",
        "metadata": "string|max:2000",
        "occurredAt": "datetime|required"
      }
    },
    "fair_play_reviews": {
      "note": "Private organizer decisions and post-game statistical screening summaries.",
      "permissions": [],
      "indexes": {
        "game_review": "key:gameId",
        "profile_review": "key:profileId,status"
      },
      "fields": {
        "gameId": "string|required",
        "tournamentId": "string|required",
        "profileId": "string|required",
        "status": "enum:clear,watch,review,confirmed,appealed",
        "riskScore": "integer|min:0|max:100",
        "accuracy": "float",
        "engineMatchRate": "float",
        "averageCentipawnLoss": "float",
        "signals": "longtext",
        "reviewedByProfileId": "string",
        "reviewedAt": "datetime",
        "createdAt": "datetime|required"
      }
    },
    "standings": {
      "fields": {
        "tournamentId": "string|required",
        "profileId": "string|required",
        "rank": "integer|required",
        "points": "float|required",
        "tieBreak": "float",
        "played": "integer|default:0",
        "wins": "integer|default:0",
        "draws": "integer|default:0",
        "losses": "integer|default:0"
      }
    },
    "announcements": {
      "fields": {
        "title": "string|required",
        "body": "string|required",
        "audience": "enum:public,members,organizers,admins",
        "status": "enum:draft,published,archived",
        "publishedAt": "datetime",
        "createdByProfileId": "string|required"
      }
    },
    "admin_audit": {
      "fields": {
        "actorProfileId": "string|required",
        "action": "string|required",
        "targetTable": "string",
        "targetRowId": "string",
        "payload": "string",
        "createdAt": "datetime|required"
      }
    },
    "identity_blocks": {
      "fields": {
        "type": "enum:email,universityId,phone",
        "value": "string|required",
        "reason": "string",
        "status": "enum:active,lifted",
        "targetUserId": "string",
        "targetProfileId": "string",
        "createdByProfileId": "string|required",
        "createdAt": "datetime|required",
        "liftedByProfileId": "string",
        "liftedAt": "datetime"
      }
    },
    "ip_blocks": {
      "fields": {
        "ipRange": "string|required",
        "reason": "string",
        "status": "enum:active,lifted",
        "createdByProfileId": "string|required",
        "createdAt": "datetime|required",
        "liftedByProfileId": "string",
        "liftedAt": "datetime"
      }
    }
  },
  "buckets": ["avatars", "tournament-assets"],
  "functions": ["admin-actions", "player-actions", "access-guards"]
}
