{
  "name": "juchess-platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/admin"
  ],
  "scripts": {
    "dev:web": "npm --workspace apps/web run dev",
    "dev:admin": "npm --workspace apps/admin run dev",
    "dev:mobile-web": "cd apps/mobile && flutter run -d web-server --web-hostname 127.0.0.1 --web-port 8063",
    "build:web": "npm --workspace apps/web run build",
    "build:admin": "npm --workspace apps/admin run build",
    "build:pages": "node scripts/build-pages.mjs",
    "check:email-templates": "node scripts/validate-email-templates.mjs",
    "seed:appwrite-demo": "node scripts/seed-appwrite-demo-data.mjs",
    "migrate:procedure": "powershell -ExecutionPolicy Bypass -File scripts/migrate-procedure-schema.ps1",
    "migrate:online-tournaments": "powershell -ExecutionPolicy Bypass -File scripts/migrate-online-tournament-schema.ps1",
    "migrate:registration-integrity": "powershell -ExecutionPolicy Bypass -File scripts/migrate-registration-integrity.ps1",
    "migrate:attendance": "powershell -ExecutionPolicy Bypass -File scripts/migrate-attendance-confirmation.ps1",
    "migrate:game-query-indexes": "powershell -ExecutionPolicy Bypass -File scripts/migrate-game-query-indexes.ps1",
    "migrate:tournament-live": "powershell -ExecutionPolicy Bypass -File scripts/migrate-tournament-live-schema.ps1",
    "migrate:profile-usernames": "powershell -ExecutionPolicy Bypass -File scripts/migrate-profile-game-usernames.ps1",
    "migrate:profile-privacy": "powershell -ExecutionPolicy Bypass -File scripts/migrate-profile-privacy.ps1",
    "migrate:profile-university": "powershell -ExecutionPolicy Bypass -File scripts/migrate-profile-university.ps1",
    "migrate:board-preferences": "powershell -ExecutionPolicy Bypass -File scripts/migrate-board-preferences.ps1",
    "migrate:registration-deadline": "powershell -ExecutionPolicy Bypass -File scripts/migrate-tournament-registration-deadline.ps1",
    "migrate:recruitment": "powershell -ExecutionPolicy Bypass -File scripts/migrate-recruitment.ps1",
    "generate:opening-book": "node scripts/generate-opening-book.mjs",
    "lint:web": "npm --workspace apps/web run lint",
    "lint:admin": "npm --workspace apps/admin run lint",
    "mobile:analyze": "cd apps/mobile && flutter analyze",
    "mobile:test": "cd apps/mobile && flutter test",
    "test:web-review": "node --experimental-strip-types --test apps/web/src/lib/gameReview.test.ts apps/web/src/lib/externalGames.test.ts apps/web/src/lib/onlineTournamentOptimism.test.ts apps/web/src/lib/storedMoves.test.ts apps/web/src/lib/boardAppearance.test.ts apps/web/src/lib/openingBook.test.ts apps/web/src/lib/tablebase.test.ts apps/web/src/lib/jordanUniversities.test.ts",
    "test:admin-wizard": "node --experimental-strip-types --test apps/admin/test/tournamentWizard.test.mjs",
    "test:engine": "cd appwrite/functions/admin-actions && node --test test/*.test.mjs",
    "test:functions": "node --test appwrite/functions/player-actions/test/*.test.mjs appwrite/functions/attendance-actions/test/*.test.mjs appwrite/functions/access-guards/test/*.test.mjs",
    "check:functions": "node --check appwrite/functions/admin-actions/src/main.js && node --check appwrite/functions/player-actions/src/main.js && node --check appwrite/functions/attendance-actions/src/main.js && node --check appwrite/functions/access-guards/src/main.js",
    "check:web": "npm run lint:web && npm run build:web && npm run test:web-review",
    "check:admin": "npm run lint:admin && npm run build:admin && npm run test:admin-wizard && npm run test:engine",
    "check:all": "npm run check:functions && npm run test:functions && npm run check:web && npm run check:admin && npm run mobile:analyze && npm run mobile:test"
  }
}
